<div class="mx-auto max-w-2xl rounded-3xl bg-white p-8 shadow-sm">
  <h1 class="text-3xl font-semibold">Tracking Service</h1>
  <p class="mt-2 text-slate-600">Masukkan kode tracking untuk melihat status service.</p>

  {{#if error}}
    <div class="mt-5 rounded-2xl border border-red-200 bg-red-50 p-4 text-red-700">{{error}}</div>
  {{/if}}

  <form action="/tracking" method="POST" class="mt-6 space-y-6">
    <label class="block">
      <span class="text-sm font-medium text-slate-700">Kode Tracking</span>
      <input name="tracking_code" value="{{old.tracking_code}}" type="text" class="mt-2 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3" placeholder="TRK-123456-ABCDEF" />
    </label>
    <button type="submit" class="inline-flex items-center rounded-2xl bg-sky-600 px-6 py-3 text-white hover:bg-sky-500">Lihat Status</button>
  </form>
</div>
