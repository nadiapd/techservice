<div class="bg-white rounded-2xl shadow p-8 max-w-3xl">

  <h2 class="text-2xl font-bold mb-8">
    Create Service
  </h2>

  <form action="/services/store" method="POST">

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <div>
        <label class="block mb-2">
          Customer Name
        </label>

        <input
          type="text"
          name="customer_name"
          class="w-full border rounded-lg p-3"
        />
      </div>

      <div>
        <label class="block mb-2">
          Customer Email
        </label>

        <input
          type="email"
          name="customer_email"
          class="w-full border rounded-lg p-3"
        />
      </div>

      <div>
        <label class="block mb-2">
          Customer Phone
        </label>

        <input
          type="text"
          name="customer_phone"
          class="w-full border rounded-lg p-3"
        />
      </div>

      <div>
        <label class="block mb-2">
          Device Name
        </label>

        <input
          type="text"
          name="device_name"
          class="w-full border rounded-lg p-3"
        />
      </div>

      <div>
        <label class="block mb-2">
          Device Category
        </label>

        <select
          name="device_category"
          id="device_category"
          class="w-full border rounded-lg p-3"
          onchange="toggleOtherCategory()"
        >
          <option value="">Select Category</option>
          <option value="laptop">Laptop</option>
          <option value="smartphone">Smartphone</option>
          <option value="printer">Printer</option>
          <option value="monitor">Monitor</option>
          <option value="televisi">Televisi</option>
          <option value="lainnya">Lainnya</option>
        </select>
      </div>

      <div id="other_category_div" style="display: none;">
        <label class="block mb-2">
          Other Category
        </label>

        <input
          type="text"
          name="device_category_other"
          class="w-full border rounded-lg p-3"
          placeholder="Specify other category"
        />
      </div>

      <script>
        function toggleOtherCategory() {
          const category = document.getElementById('device_category').value;
          const otherDiv = document.getElementById('other_category_div');
          if (category === 'lainnya') {
            otherDiv.style.display = 'block';
          } else {
            otherDiv.style.display = 'none';
          }
        }
      </script>

    </div>

    <div class="mt-6">

      <label class="block mb-2">
        Complaint
      </label>

      <textarea
        name="complaint"
        rows="5"
        class="w-full border rounded-lg p-3"
      ></textarea>

    </div>

    <button
      type="submit"
      class="mt-8 bg-slate-900 text-white px-6 py-3 rounded-lg"
    >
      Save Service
    </button>

  </form>

</div>