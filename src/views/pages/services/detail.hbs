<div class="space-y-8">
  <div class="rounded-3xl bg-white p-8 shadow-sm">
    <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
      <div>
        <h1 class="text-3xl font-semibold">Detail Service</h1>
        <p class="text-slate-600">Tracking code: <span class="font-medium text-sky-600">{{service.tracking_code}}</span></p>
      </div>
      <span class="inline-flex items-center rounded-full bg-slate-100 px-4 py-2 text-sm capitalize">{{service.status}}</span>
    </div>

    {{#if error}}
      <div class="mt-5 rounded-2xl border border-red-200 bg-red-50 p-4 text-red-700">{{error}}</div>
    {{/if}}

    <div class="mt-6 grid gap-6 md:grid-cols-2">
      <div class="rounded-2xl bg-slate-50 p-5">
        <h2 class="font-semibold">Data Customer</h2>
        <p class="mt-3 text-slate-700">Nama: {{service.customer.name}}</p>
        <p class="text-slate-700">Email: {{service.customer.email}}</p>
        <p class="text-slate-700">Phone: {{service.customer.phone}}</p>
      </div>
      <div class="rounded-2xl bg-slate-50 p-5">
        <h2 class="font-semibold">Detail Perangkat</h2>
        <p class="mt-3 text-slate-700">Perangkat: {{service.device_name}}</p>
        <p class="text-slate-700">Merk: {{service.device_brand}}</p>
        <p class="text-slate-700">Kategori: {{service.category.category_name}}</p>
      </div>
    </div>

    <div class="rounded-2xl bg-slate-50 p-5">
      <h2 class="font-semibold">Deskripsi Kerusakan</h2>
      <p class="mt-3 text-slate-700">{{service.complaint}}</p>
    </div>

    <div class="rounded-2xl bg-slate-50 p-5">
      <h2 class="font-semibold">History Status</h2>
      <div class="mt-4 space-y-3">
        {{#each service.service_logs}}
          <div class="rounded-2xl bg-white p-4 shadow-sm">
            <div class="flex items-center justify-between gap-3">
              <span class="font-medium capitalized">{{status}}</span>
              <span class="text-sm text-slate-500">{{formatDate created_at}}</span>
            </div>
            <p class="mt-2 text-slate-600">{{note}}</p>
            <p class="mt-1 text-xs text-slate-400">Updated by: {{updated_by}}</p>
          </div>
        {{else}}
          <p class="text-slate-600">Belum ada histori update.</p>
        {{/each}}
      </div>
    </div>
  </div>

  <div class="rounded-3xl bg-white p-8 shadow-sm">
    <h2 class="text-2xl font-semibold">Update Status Service</h2>
    <form action="/admin/services/{{service.id}}/status" method="POST" class="mt-6 space-y-6">
      <div>
        <label class="block text-sm font-medium text-slate-700">Status</label>
        <select name="status" class="mt-2 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3">
          <option value="pending" {{#ifEquals service.status 'pending'}}selected{{/ifEquals}}>pending</option>
          <option value="checking" {{#ifEquals service.status 'checking'}}selected{{/ifEquals}}>checking</option>
          <option value="repairing" {{#ifEquals service.status 'repairing'}}selected{{/ifEquals}}>repairing</option>
          <option value="completed" {{#ifEquals service.status 'completed'}}selected{{/ifEquals}}>completed</option>
          <option value="cancelled" {{#ifEquals service.status 'cancelled'}}selected{{/ifEquals}}>cancelled</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700">Catatan</label>
        <textarea name="note" rows="4" class="mt-2 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3"></textarea>
      </div>
      <button type="submit" class="inline-flex items-center rounded-2xl bg-sky-600 px-6 py-3 text-white hover:bg-sky-500">Update Status</button>
    </form>
  </div>
</div>
