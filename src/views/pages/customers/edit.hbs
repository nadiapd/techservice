<div class="bg-white rounded-2xl shadow p-8 max-w-3xl">

  <h2 class="text-2xl font-bold mb-8">
    Edit Customer
  </h2>

  <form action="/customers/{{customer.id}}/update" method="POST">

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <div>
        <label class="block mb-2">
          Name
        </label>

        <input
          type="text"
          name="name"
          class="w-full border rounded-lg p-3"
          value="{{#if old.name}}{{old.name}}{{else}}{{customer.name}}{{/if}}"
        />

        {{#if errors.name}}
        <p class="text-red-500 text-sm mt-1">{{errors.name.0}}</p>
        {{/if}}
      </div>

      <div>
        <label class="block mb-2">
          Email
        </label>

        <input
          type="email"
          name="email"
          class="w-full border rounded-lg p-3"
          value="{{#if old.email}}{{old.email}}{{else}}{{customer.email}}{{/if}}"
        />

        {{#if errors.email}}
        <p class="text-red-500 text-sm mt-1">{{errors.email.0}}</p>
        {{/if}}
      </div>

      <div>
        <label class="block mb-2">
          Phone
        </label>

        <input
          type="text"
          name="phone"
          class="w-full border rounded-lg p-3"
          value="{{#if old.phone}}{{old.phone}}{{else}}{{customer.phone}}{{/if}}"
        />

        {{#if errors.phone}}
        <p class="text-red-500 text-sm mt-1">{{errors.phone.0}}</p>
        {{/if}}
      </div>

    </div>

    <div class="mt-6">
      <button
        type="submit"
        class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded"
      >
        Update Customer
      </button>

      <a
        href="/customers"
        class="ml-4 text-gray-600 hover:text-gray-800"
      >
        Cancel
      </a>
    </div>

  </form>

</div>