<div class="max-w-xl mx-auto bg-white p-8 rounded-2xl shadow">

  <h1 class="text-3xl font-bold mb-4">
    Tracking Service
  </h1>

  <p class="text-slate-500 mb-8">
    Input your tracking code to check service status.
  </p>

  <form action="/tracking" method="GET">

    <input
      type="text"
      name="tracking_code"
      placeholder="Input tracking code"
      class="w-full border rounded-lg p-3 mb-4"
    />

    <button
      type="submit"
      class="w-full bg-slate-900 text-white p-3 rounded-lg"
    >
      Check Status
    </button>

  </form>

</div>